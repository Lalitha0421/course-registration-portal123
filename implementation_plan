## 🗂️ Missing Tables to Add to Schema

```sql
-- Already in code, missing from schema
CREATE TABLE student_registration_courses (
    id NUMBER PRIMARY KEY,
    student_id NUMBER NOT NULL,
    course_instance_id NUMBER NOT NULL,
    academic_session VARCHAR2(20),
    registration_date DATE DEFAULT SYSDATE,
    CONSTRAINT fk_src_student FOREIGN KEY (student_id) REFERENCES students(student_id),
    CONSTRAINT fk_src_instance FOREIGN KEY (course_instance_id) REFERENCES course_instance(instance_id)
);

-- Used in student_routes but missing
CREATE TABLE system_config (
    config_key VARCHAR2(50) PRIMARY KEY,
    config_value VARCHAR2(200),
    updated_at DATE DEFAULT SYSDATE
);

-- You requested these
CREATE TABLE program_outcomes (
    po_id NUMBER PRIMARY KEY,
    po_code VARCHAR2(10),
    po_description VARCHAR2(500)
);

CREATE TABLE co_po_mapping (
    id NUMBER PRIMARY KEY,
    course_outcome_id NUMBER,
    program_outcome_id NUMBER,
    weightage NUMBER(3),
    CONSTRAINT fk_copo_co FOREIGN KEY (course_outcome_id) REFERENCES course_outcomes(outcome_id),
    CONSTRAINT fk_copo_po FOREIGN KEY (program_outcome_id) REFERENCES program_outcomes(po_id)
);

CREATE TABLE evaluation_details (
    eval_id NUMBER PRIMARY KEY,
    course_id NUMBER,
    component_name VARCHAR2(100),
    weightage_percent NUMBER(5,2),
    CONSTRAINT fk_eval_course FOREIGN KEY (course_id) REFERENCES course_master(course_id)
);

CREATE TABLE course_equivalents (
    id NUMBER PRIMARY KEY,
    course_id NUMBER,
    equivalent_course_id NUMBER,
    CONSTRAINT fk_ceq_course FOREIGN KEY (course_id) REFERENCES course_master(course_id),
    CONSTRAINT fk_ceq_equiv FOREIGN KEY (equivalent_course_id) REFERENCES course_master(course_id)
);

-- Coordinator: 1 faculty per 10 students
CREATE TABLE course_coordinator (
    id NUMBER PRIMARY KEY,
    faculty_id NUMBER,
    student_id NUMBER,
    academic_session VARCHAR2(20),
    CONSTRAINT fk_cc_faculty FOREIGN KEY (faculty_id) REFERENCES faculty(faculty_id),
    CONSTRAINT fk_cc_student FOREIGN KEY (student_id) REFERENCES students(student_id)
);
```

